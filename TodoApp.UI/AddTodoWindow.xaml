<Window x:Class="TodoApp.UI.AddTodoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adicionar/Editar Tarefa" Height="400" Width="500" Background="#ECEFF1" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <StackPanel Padding="20">
        <TextBlock Text="📝 Detalhes da Tarefa" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <TextBlock Text="Título" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="TitleBox" Height="35" Padding="10" Background="White" Foreground="#263238"/>
        
        <TextBlock Text="Descrição" FontSize="12" FontWeight="Bold" Margin="0,15,0,5"/>
        <TextBox x:Name="DescriptionBox" Height="70" Padding="10" Background="White" Foreground="#263238" TextWrapping="Wrap" AcceptsReturn="True"/>
        
        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Categoria" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CategoryBox" Height="35" Background="White" Foreground="#263238" Padding="10">
                    <ComboBoxItem Content="Trabalho"/>
                    <ComboBoxItem Content="Pessoal" IsSelected="True"/>
                    <ComboBoxItem Content="Compras"/>
                    <ComboBoxItem Content="Saúde"/>
                    <ComboBoxItem Content="Outros"/>
                </ComboBox>
            </StackPanel>
            
            <StackPanel Grid.Column="1">
                <TextBlock Text="Prioridade" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="PriorityBox" Height="35" Background="White" Foreground="#263238" Padding="10">
                    <ComboBoxItem Content="Baixa"/>
                    <ComboBoxItem Content="Média" IsSelected="True"/>
                    <ComboBoxItem Content="Alta"/>
                </ComboBox>
            </StackPanel>
        </Grid>
        
        <TextBlock Text="Data de Vencimento" FontSize="12" FontWeight="Bold" Margin="0,15,0,5"/>
        <DatePicker x:Name="DueDatePicker" Height="35" Background="White" Foreground="#263238" Padding="10"/>
        
        <StackPanel Orientation="Horizontal" Margin="0,25,0,0" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="100" Height="35" Background="#757575" Foreground="White" 
                    Click="Cancel_Click" Cursor="Hand" Margin="0,0,10,0"/>
            <Button Content="Salvar" Width="100" Height="35" Background="#4CAF50" Foreground="White" 
                    Click="Save_Click" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
