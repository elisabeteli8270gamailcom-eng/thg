<Window x:Class="TodoApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 Todo App" Height="700" Width="1000" Background="#ECEFF1" Foreground="#263238">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#37474F" Padding="15">
            <TextBlock Text="📋 Categorias" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
            <ListBox x:Name="CategoriesListBox" Background="#455A64" Foreground="White" Margin="0,0,0,20" SelectionChanged="Category_SelectionChanged">
                <ListBoxItem Content="📌 Todos" IsSelected="True"/>
                <ListBoxItem Content="⏰ Atrasados"/>
                <Separator/>
                <ListBoxItem Content="🏢 Trabalho"/>
                <ListBoxItem Content="👤 Pessoal"/>
                <ListBoxItem Content="🛒 Compras"/>
                <ListBoxItem Content="❤️ Saúde"/>
                <ListBoxItem Content="📌 Outros"/>
            </ListBox>
            
            <TextBlock Text="📊 Estatísticas" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,20,0,10"/>
            <TextBlock x:Name="TotalCount" Text="Total: 0" Foreground="#B0BEC5" Margin="0,5"/>
            <TextBlock x:Name="CompletedCount" Text="Completos: 0" Foreground="#81C784" Margin="0,5"/>
            <TextBlock x:Name="PendingCount" Text="Pendentes: 0" Foreground="#E57373" Margin="0,5"/>
            <TextBlock x:Name="OverdueCount" Text="Atrasados: 0" Foreground="#FFB74D" Margin="0,5"/>
        </StackPanel>

        <!-- Main Content -->
        <StackPanel Grid.Column="1" Padding="25">
            <!-- Header -->
            <TextBlock Text="Minhas Tarefas" FontSize="32" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Search and Add -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBox x:Name="SearchBox" Width="300" Height="40" Padding="10" TextChanged="Search_TextChanged"
                         Background="White" Foreground="#263238"/>
                <Button Content="➕ Nova Tarefa" Width="150" Height="40" Margin="10,0,0,0" 
                        Background="#2196F3" Foreground="White" FontWeight="Bold" 
                        Click="AddTodo_Click" Cursor="Hand"/>
                <Button Content="🗑️ Limpar Completos" Width="150" Height="40" Margin="10,0,0,0" 
                        Background="#FF9800" Foreground="White" FontWeight="Bold" 
                        Click="ClearCompleted_Click" Cursor="Hand"/>
            </StackPanel>

            <!-- Todos List -->
            <ListBox x:Name="TodosListBox" Background="White" Margin="0,0,0,0" Height="500">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox x:Name="CompleteCheckbox" Grid.Column="0" VerticalAlignment="Center"
                                         Click="TodoComplete_Click" Tag="{Binding Id}"/>
                                
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#757575" Margin="0,5,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#90A4AE" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Priority}" FontSize="10" Foreground="#90A4AE" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding DueDate, StringFormat='🗓️ {0:dd/MM/yyyy}'}" FontSize="10" Foreground="#FF9800"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <Button Grid.Column="2" Content="✏️ Editar" Width="80" Height="30" 
                                       Background="#2196F3" Foreground="White" FontSize="11"
                                       Click="EditTodo_Click" Tag="{Binding Id}" Cursor="Hand"/>
                                
                                <Button Grid.Column="3" Content="🗑️ Deletar" Width="70" Height="30" Margin="5,0,0,0"
                                       Background="#F44336" Foreground="White" FontSize="11"
                                       Click="DeleteTodo_Click" Tag="{Binding Id}" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>
