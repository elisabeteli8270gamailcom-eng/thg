<Window x:Class="FiveMOptimizer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FiveM Optimizer" Height="600" Width="900" Background="#F0F0F0" Foreground="#333333">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="20">
            <!-- Header -->
            <TextBlock Text="🚀 FiveM Optimizer" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
            
            <!-- System Info Section -->
            <GroupBox Header="📊 Informações do Sistema" Padding="15" Margin="0,0,0,15" Foreground="#2C3E50">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="{Binding SystemInfo.ComputerName, StringFormat='Computador: {0}'}" Margin="0,5"/>
                        <TextBlock Text="{Binding SystemInfo.OsVersion, StringFormat='Sistema: {0}'}" Margin="0,5"/>
                        <TextBlock Text="{Binding SystemInfo.ProcessorName, StringFormat='Processador: {0}'}" Margin="0,5"/>
                        <TextBlock Text="{Binding SystemInfo.ProcessorCores, StringFormat='Núcleos: {0}'}" Margin="0,5"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding SystemInfo.MemoryUsagePercent, StringFormat='Memória: {0:0.0}%'}" Margin="0,5"/>
                        <ProgressBar Height="10" Value="{Binding SystemInfo.MemoryUsagePercent}" Maximum="100" Margin="0,5"/>
                        <TextBlock Text="{Binding SystemInfo.DiskUsagePercent, StringFormat='Disco: {0:0.0}%'}" Margin="0,5"/>
                        <ProgressBar Height="10" Value="{Binding SystemInfo.DiskUsagePercent}" Maximum="100" Margin="0,5"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Optimization Options -->
            <GroupBox Header="⚙️ Opções de Otimização" Padding="15" Margin="0,0,0,15" Foreground="#2C3E50">
                <StackPanel Orientation="Vertical">
                    <CheckBox Content="Limpar Arquivos Temporários" IsChecked="{Binding Settings.EnableCleanTemp}" Margin="0,5"/>
                    <CheckBox Content="Limpar Cache" IsChecked="{Binding Settings.EnableCleanCache}" Margin="0,5"/>
                    <CheckBox Content="Otimizar Processos" IsChecked="{Binding Settings.EnableOptimizeProcesses}" Margin="0,5"/>
                    <CheckBox Content="Otimização de Rede" IsChecked="{Binding Settings.EnableNetworkOptimization}" Margin="0,5"/>
                    <CheckBox Content="Otimização de Memória" IsChecked="{Binding Settings.EnableMemoryOptimization}" Margin="0,5"/>
                    <CheckBox Content="Otimização de GPU" IsChecked="{Binding Settings.EnableGpuOptimization}" Margin="0,5"/>
                    <CheckBox Content="Otimização de Disco" IsChecked="{Binding Settings.EnableDiskOptimization}" Margin="0,5"/>
                    <CheckBox Content="Criar Ponto de Restauração" IsChecked="{Binding Settings.CreateRestorePoint}" Margin="0,5"/>
                </StackPanel>
            </GroupBox>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Button Content="🔧 Otimizar Agora" Width="150" Height="40" Background="#27AE60" Foreground="White" 
                        FontSize="12" FontWeight="Bold" Margin="5" Click="OptimizeButton_Click" Cursor="Hand"/>
                <Button Content="🔄 Atualizar" Width="150" Height="40" Background="#3498DB" Foreground="White" 
                        FontSize="12" FontWeight="Bold" Margin="5" Click="RefreshButton_Click" Cursor="Hand"/>
                <Button Content="❌ Sair" Width="150" Height="40" Background="#E74C3C" Foreground="White" 
                        FontSize="12" FontWeight="Bold" Margin="5" Click="ExitButton_Click" Cursor="Hand"/>
            </StackPanel>

            <!-- Results Section -->
            <GroupBox Header="📋 Resultados da Otimização" Padding="15" Margin="0,0,0,0" Foreground="#2C3E50">
                <ListBox ItemsSource="{Binding Results}" Height="120">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding ModuleName, StringFormat='[{0}]'}" FontWeight="Bold"/>
                                <Run Text=": "/>
                                <Run Text="{Binding Message}"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding ExecutionTime.TotalMilliseconds, StringFormat='{0:0}ms'}" Foreground="Gray"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>
